DJANGO_ENV=development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local Docker default. Replace with your Supabase PostgreSQL connection string in production.
DATABASE_URL=postgres://postgres:postgres@db:5432/teamtask
# Supabase example:
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_COOKIE_SECURE=False
DJANGO_SUPERUSER_EMAIL=admin@teamtask.dev
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
DJANGO_SUPERUSER_USERNAME=admin
